{
  "name": "codex-fastmcp-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "codex-fastmcp-template": "./src/index.ts"
  },
  "exports": {
    ".": "./src/server.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/start.ts",
    "server": "bun run src/index.ts",
    "build": "bun run clean && bun build src/index.ts src/server.ts src/lifecycle.ts src/tools/health.ts --outdir dist --target bun --format esm --external fastmcp --external zod",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bunx @biomejs/biome@2.5.4 check --config-path ./biome.jsonc ./biome.jsonc ./package.json ./tsconfig.json ./src ./test",
    "validate:stdio": "bun run src/validate-stdio.ts",
    "inspect:browser": "fastmcp inspect src/index.ts",
    "dev": "fastmcp dev src/index.ts"
  },
  "dependencies": {
    "fastmcp": "^4.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
