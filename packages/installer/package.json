{
  "name": "@skizzles/installer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --target=bun --format=esm --outdir=./dist",
    "check": "bunx @biomejs/biome@2.5.4 check --config-path ../../biome.jsonc --vcs-root ../.. .",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@skizzles/container-lab": "workspace:*",
    "@skizzles/prompt-layer": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
