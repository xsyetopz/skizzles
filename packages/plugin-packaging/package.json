{
  "name": "@skizzles/plugin-packaging",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/plugin/api.ts",
    "./agent-contract": "./src/agent-contract/api.ts"
  },
  "bin": {
    "skizzles-plugin-builder": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build src/plugin/api.ts src/agent-contract/api.ts --target=bun --outdir=dist --root=src && bun build src/cli.ts --target=bun --outfile=dist/plugin-builder.js",
    "check": "bunx @biomejs/biome@2.5.4 check --config-path ../../biome.jsonc --vcs-root ../.. ./src ./test ./package.json ./tsconfig.json",
    "test": "bun test --timeout 30000 test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@skizzles/command-routing": "workspace:*",
    "@skizzles/command-observation": "workspace:*",
    "@skizzles/container-lab": "workspace:*",
    "@skizzles/installer": "workspace:*",
    "@skizzles/model-catalog": "workspace:*",
    "@skizzles/prompt-policy": "workspace:*",
    "@skizzles/scratchspace": "workspace:*",
    "@skizzles/usage-analysis": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
