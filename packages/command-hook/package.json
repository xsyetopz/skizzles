{
  "name": "@skizzles/command-hook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./hooks.json": "./assets/hooks.json"
  },
  "bin": {
    "skizzles-manage-command-output": "./src/manage-command-output.ts"
  },
  "scripts": {
    "build": "bun build src/manage-command-output.ts --target=bun --outfile=dist/manage-command-output.js",
