{
  "name": "@skizzles/workspace-policy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/workspace/policy.ts"
  },
  "bin": {
    "skizzles-workspace-policy": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/biome-suppressions.ts ./src/cli.ts ./src/security-cli.ts ./src/workspace/policy.ts --target=bun --format=esm --outdir=./dist --external typescript --external 'typescript/*'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./test",
    "check": "bunx @biomejs/biome@2.5.4 check --config-path ../../biome.jsonc --vcs-root ../.. ./src ./test package.json tsconfig.json"
  },
  "dependencies": {
    "@skizzles/run-workspace": "workspace:*",
    "typescript": "7.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1"
  }
}
