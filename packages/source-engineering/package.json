{
  "name": "@skizzles/source-engineering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --format=esm --outdir=dist --external typescript --external 'typescript/*'",
    "check": "bunx @biomejs/biome@2.5.4 check --config-path ../../biome.jsonc --vcs-root ../.. .",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@skizzles/candidate-manifest": "workspace:*",
    "@skizzles/run-workspace": "workspace:*",
    "typescript": "7.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1"
  }
}
