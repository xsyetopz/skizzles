{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xsyetopz.github.io/skizzles/contracts/acceptance/v3.schema.json",
  "title": "Completion Contract acceptance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "objective",
    "acceptance",
    "run",
    "requirements",
    "objectiveGates",
    "evaluationOrder",
    "artifacts",
    "evidence",
    "effects",
    "findings",
    "execution",
    "policy",
    "validator",
    "judge",
    "authors"
  ],
  "properties": {
    "schemaVersion": {
      "const": "3.0.0"
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "digest"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "startedAt", "completedAt", "expiresAt"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "obligation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9-]{1,31}$"
          },
          "obligation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "objectiveGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "requirementId",
          "check",
          "proofKind",
          "result",
          "evidenceRefs"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "requirementId": {
            "type": "string",
            "minLength": 1
          },
          "check": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
            }
          },
          "proofKind": {
            "type": "string",
            "enum": ["runtime-effect", "test-result"]
          }
        }
      }
    },
    "evaluationOrder": {
      "type": "array",
      "prefixItems": [
        {
          "const": "objectiveGates"
        },
        {
          "const": "judge"
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "sha256"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          },
          "kind": {
            "type": "string",
            "enum": ["implementation", "verifier", "test-suite"]
          },
          "sha256": {
            "$ref": "#/$defs/digest"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "ref",
          "artifactRef",
          "effectRef",
          "sha256",
          "outcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "test-result",
              "runtime-effect",
              "artifact-hash",
              "inspection",
              "process-exit",
              "success-token"
            ]
          },
          "ref": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          },
          "artifactRef": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
              }
            ]
          },
          "effectRef": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
              }
            ]
          },
          "sha256": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/$defs/digest"
              }
            ]
          },
          "outcome": {
            "type": "string",
            "enum": ["pass", "fail", "observed", "missing"]
          }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claimed", "observed", "evidenceRef"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          },
          "claimed": {
            "type": "boolean"
          },
          "observed": {
            "type": "boolean"
          },
          "evidenceRef": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "verifier-mutation",
              "test-mutation",
              "solution-leakage",
              "grader-injection",
              "hard-coded-answer",
              "deceptive-completion"
            ]
          },
          "ref": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retries", "seed"],
      "properties": {
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "digest", "modelVersion", "modelDigest"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "modelVersion": {
          "type": "string",
          "minLength": 1
        },
        "modelDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "judge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "version",
        "promptSha256",
        "ranAfterObjectiveGates",
        "decision"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "promptSha256": {
          "$ref": "#/$defs/digest"
        },
        "ranAfterObjectiveGates": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": ["not-run", "pass", "fail"]
        }
      }
    },
    "authors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "reviewer", "selfReview"],
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "selfReview": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
