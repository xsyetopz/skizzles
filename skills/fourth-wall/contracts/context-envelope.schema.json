{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xsyetopz.github.io/skizzles/contracts/context-envelope/v1.schema.json",
  "title": "Fourth Wall context envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contextId", "properties"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "contextId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contextProperty" }
    }
  },
  "$defs": {
    "contextProperty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "origin",
        "createdAt",
        "trustClass",
        "integrity",
        "scope",
        "objective",
        "policyVersion",
        "retention",
        "sensitivity",
        "redaction",
        "transformations",
        "validation"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9._-]{0,63}$" },
        "value": {},
        "origin": {
          "type": "string",
          "enum": [
            "user",
            "repository",
            "tool",
            "agent",
            "generated",
            "external"
          ]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "trustClass": {
          "type": "string",
          "enum": ["untrusted", "validated", "trusted"]
        },
        "integrity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "sha256"],
          "properties": {
            "algorithm": { "const": "sha-256" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "scope": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["class", "expiresAt"],
          "properties": {
            "class": {
              "type": "string",
              "enum": ["ephemeral", "session", "persistent"]
            },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "sensitivity": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "secret"]
        },
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "applied"],
          "properties": {
            "required": { "type": "boolean" },
            "applied": { "type": "boolean" },
            "method": { "type": "string" }
          }
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "producer"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "none",
                  "parse",
                  "summarize",
                  "translate",
                  "redact",
                  "normalize"
                ]
              },
              "producer": { "type": "string", "minLength": 1 },
              "at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["property", "status", "validator", "evidence"],
          "properties": {
            "property": { "type": "string", "minLength": 1 },
            "status": {
              "type": "string",
              "enum": [
                "unvalidated",
                "valid",
                "invalid",
                "stale",
                "expired",
                "redacted"
              ]
            },
            "validator": { "type": "string", "minLength": 1 },
            "evidence": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9._/-]{1,200}$"
              }
            }
          }
        }
      }
    }
  }
}
